<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Justin's Property Affordability Calculator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --navy: #0A1628; --navy-mid: #122040; --navy-light: #1D3056;
  --gold: #C9A84C; --gold-light: #E4C878; --gold-dim: rgba(201,168,76,0.15);
  --white: #FFFFFF; --slate: #8A9BB0; --slate-light: #B4C2D0;
  --border: rgba(138,155,176,0.25); --border-strong: rgba(138,155,176,0.45);
  --green: #2ECC7A; --green-dim: rgba(46,204,122,0.12);
  --red: #E8485A; --red-dim: rgba(232,72,90,0.12);
  --amber: #F5A623; --amber-dim: rgba(245,166,35,0.12);
  --radius: 12px; --radius-sm: 8px; --radius-lg: 18px;
}

html { -webkit-text-size-adjust: 100%; }
body {
  font-family: 'Inter', sans-serif;
  background: var(--navy);
  color: var(--white);
  min-height: 100vh;
  padding: 16px 14px 56px;
  line-height: 1.5;
  font-size: 14px;
}

/* ── HEADER ── */
.page-header {
  max-width: 980px; margin: 0 auto 18px;
  display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
}
.page-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(17px, 4.5vw, 26px);
  font-weight: 700; color: var(--white); letter-spacing: -0.5px; line-height: 1.2;
}
.page-title span { color: var(--gold); }
.page-subtitle { font-size: 11px; color: var(--slate); margin-top: 4px; }
.reset-btn {
  font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 500;
  color: var(--slate); background: transparent;
  border: 1px solid var(--border-strong); border-radius: 6px;
  padding: 8px 14px; cursor: pointer; white-space: nowrap; flex-shrink: 0;
  -webkit-tap-highlight-color: transparent;
}

/* ── LAYOUT ── */
.layout {
  max-width: 980px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 290px; gap: 14px; align-items: start;
}
/* Mobile: sidebar moves below main content */
@media (max-width: 700px) {
  .layout { grid-template-columns: 1fr; }
  .side-card { position: static; }
}

/* ── CARDS ── */
.card { background: var(--navy-mid); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
.card + .card { margin-top: 14px; }
.card-section { padding: 16px 16px; border-bottom: 1px solid var(--border); }
.card-section:last-child { border-bottom: none; }
.section-label {
  font-family: 'Space Grotesk', sans-serif; font-size: 10px; font-weight: 600;
  letter-spacing: 1.2px; text-transform: uppercase; color: var(--gold); margin-bottom: 12px;
}

/* ── PRICE HERO ── */
.price-hero {
  padding: 20px 16px 16px;
  background: linear-gradient(135deg, var(--navy-light) 0%, var(--navy-mid) 100%);
  border-bottom: 1px solid var(--border);
}
.price-label { font-size: 12px; font-weight: 500; color: var(--slate); margin-bottom: 8px; }
.price-input-wrap {
  display: flex; align-items: center; gap: 8px;
  background: rgba(255,255,255,0.05); border: 1.5px solid var(--gold);
  border-radius: var(--radius); padding: 10px 14px;
}
.price-input-wrap:focus-within { box-shadow: 0 0 0 3px rgba(201,168,76,0.2); }
.price-prefix { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 600; color: var(--gold); white-space: nowrap; }
.price-input {
  font-family: 'Space Grotesk', sans-serif; font-size: clamp(22px, 6vw, 28px);
  font-weight: 700; color: var(--white); background: transparent;
  border: none; outline: none; width: 100%; min-width: 0;
  letter-spacing: -0.5px; -moz-appearance: textfield;
}
.price-input::-webkit-outer-spin-button, .price-input::-webkit-inner-spin-button { -webkit-appearance: none; }
.price-input::placeholder { color: rgba(255,255,255,0.2); }

/* ── SANITY BAR ── */
.sanity-bar { margin-top: 14px; }
.sanity-track { height: 7px; background: rgba(255,255,255,0.08); border-radius: 4px; overflow: hidden; position: relative; }
.sanity-fill-loan { position: absolute; left: 0; top: 0; height: 100%; border-radius: 4px 0 0 4px; transition: width .4s ease; }
.sanity-fill-deposit { position: absolute; top: 0; height: 100%; border-radius: 0 4px 4px 0; transition: left .4s ease, width .4s ease; background: rgba(201,168,76,0.5); }
.sanity-labels { display: flex; justify-content: space-between; margin-top: 7px; font-size: 10px; color: var(--slate); gap: 4px; flex-wrap: wrap; }
.sanity-status { font-size: 11px; font-weight: 600; margin-top: 5px; min-height: 16px; }

/* ── INPUTS ── */
.input-grid { display: grid; gap: 10px; }
.input-grid.col2 { grid-template-columns: 1fr 1fr; }
.input-grid.col3 { grid-template-columns: 1fr 1fr 1fr; }
.input-grid.col4 { grid-template-columns: 1fr 1fr; } /* 4-col always 2x2 on mobile */
@media (max-width: 480px) {
  .input-grid.col2 { grid-template-columns: 1fr 1fr; }
  .input-grid.col3 { grid-template-columns: 1fr 1fr; }
}

.field { display: flex; flex-direction: column; gap: 5px; }
.field-label { font-size: 11px; font-weight: 500; color: var(--slate); }
.field-input {
  font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 600;
  color: var(--white); background: rgba(255,255,255,0.06);
  border: 1px solid var(--border-strong); border-radius: var(--radius-sm);
  padding: 10px 10px; outline: none; width: 100%;
  transition: border-color .15s, box-shadow .15s;
  -moz-appearance: textfield;
  /* Prevent iOS zoom on focus — needs font-size >= 16px equivalent */
  font-size: max(14px, 16px);
}
.field-input::-webkit-outer-spin-button, .field-input::-webkit-inner-spin-button { -webkit-appearance: none; }
.field-input:focus { border-color: var(--gold); box-shadow: 0 0 0 2px rgba(201,168,76,0.15); }
.field-input.auto { color: var(--slate-light); border-style: dashed; }
.field-input.auto:focus { color: var(--white); border-style: solid; }
.field-hint { font-size: 10px; color: var(--slate); }
.field-hint.auto-hint { color: var(--amber); }

/* ── LOAN TABLE — mobile scrollable ── */
.table-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
.loan-table { width: 100%; border-collapse: collapse; font-size: 12px; min-width: 340px; }
.loan-table th {
  font-size: 10px; font-weight: 600; letter-spacing: 0.8px; text-transform: uppercase;
  color: var(--slate); text-align: right; padding: 0 6px 8px; white-space: nowrap;
}
.loan-table th:first-child { text-align: left; padding-left: 0; }
.loan-table td {
  padding: 9px 6px; border-top: 1px solid var(--border); text-align: right;
  font-family: 'Space Grotesk', sans-serif; font-weight: 500; color: var(--slate-light); white-space: nowrap;
}
.loan-table td:first-child { text-align: left; font-family: 'Inter', sans-serif; padding-left: 0; color: var(--white); font-size: 12px; }
.loan-table tr:first-child td { border-top: none; }
.loan-table .total-row td { border-top: 1.5px solid var(--border-strong); font-weight: 700; color: var(--white); padding-top: 10px; }

.tag { display: inline-block; font-size: 9px; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; padding: 2px 5px; border-radius: 4px; margin-left: 4px; vertical-align: middle; }
.tag-bank { background: rgba(52,152,255,0.15); color: #5BB3FF; }
.tag-nht  { background: var(--gold-dim); color: var(--gold); }
.tag-auto { background: rgba(46,204,122,0.12); color: var(--green); font-size: 8px; }

/* ── NHT INCOME BAND ── */
.band-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.band-btn {
  font-family: 'Space Grotesk', sans-serif; font-size: 11px; font-weight: 600;
  color: var(--slate-light); background: rgba(255,255,255,0.05);
  border: 1px solid var(--border-strong); border-radius: var(--radius-sm);
  padding: 11px 8px; cursor: pointer; text-align: center; line-height: 1.4;
  transition: all .15s; -webkit-tap-highlight-color: transparent;
}
.band-btn.active { background: var(--gold-dim); border-color: var(--gold); color: var(--gold); }
.band-btn .band-rate { display: block; font-size: 18px; font-weight: 700; margin-top: 2px; }
.band-btn .band-range { display: block; font-size: 9px; font-weight: 400; opacity: 0.75; margin-top: 2px; }

/* ── FEE ROWS ── */
.fee-row { display: flex; align-items: center; justify-content: space-between; padding: 9px 0; border-bottom: 1px solid var(--border); gap: 12px; }
.fee-row:last-child { border-bottom: none; padding-bottom: 0; }
.fee-row:first-child { padding-top: 0; }
.fee-name { font-size: 12px; color: var(--slate-light); flex: 1; min-width: 0; }
.fee-name small { display: block; font-size: 10px; color: var(--slate); margin-top: 2px; }
.fee-value { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 600; color: var(--white); text-align: right; white-space: nowrap; }
.fee-gct-note { font-size: 9px; font-weight: 400; color: var(--amber); display: block; text-align: right; margin-top: 1px; }

.subtotal-row { display: flex; justify-content: space-between; align-items: center; padding: 11px 12px; background: rgba(255,255,255,0.04); border-radius: var(--radius-sm); margin-top: 12px; }
.subtotal-label { font-size: 12px; font-weight: 500; color: var(--slate-light); }
.subtotal-value { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 700; color: var(--white); }

/* ── YES/NO ── */
.yn-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 12px; }
.yn-label { font-size: 13px; color: var(--white); font-weight: 500; line-height: 1.4; }
.yn-sub { font-size: 10px; color: var(--slate); margin-top: 3px; }
.yn-btns { display: flex; gap: 6px; flex-shrink: 0; }
.yn-btn {
  font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 700;
  padding: 8px 16px; border-radius: 6px; border: 1px solid var(--border-strong);
  background: transparent; color: var(--slate-light); cursor: pointer;
  transition: all .15s; letter-spacing: 0.5px; -webkit-tap-highlight-color: transparent;
}
.yn-btn.active-yes { background: var(--green-dim); border-color: rgba(46,204,122,0.4); color: var(--green); }
.yn-btn.active-no  { background: var(--red-dim);   border-color: rgba(232,72,90,0.3);  color: var(--red); }

.nht-deduction { display: flex; justify-content: space-between; align-items: center; padding: 11px 12px; background: var(--green-dim); border: 1px solid rgba(46,204,122,0.25); border-radius: var(--radius-sm); margin-top: 6px; }
.nht-deduction-label { font-size: 12px; font-weight: 500; color: var(--green); display: flex; align-items: center; gap: 5px; }
.nht-deduction-label::before { content: '↓'; font-size: 13px; font-weight: 700; }
.nht-deduction-value { font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 700; color: var(--green); }

.out-of-pocket { display: flex; justify-content: space-between; align-items: center; padding: 14px 14px; background: var(--gold-dim); border: 1.5px solid rgba(201,168,76,0.4); border-radius: var(--radius-sm); margin-top: 8px; }
.oop-label { font-family: 'Space Grotesk', sans-serif; font-size: 12px; font-weight: 600; color: var(--gold-light); }
.oop-value { font-family: 'Space Grotesk', sans-serif; font-size: 20px; font-weight: 700; color: var(--gold); }

/* ── SIDEBAR ── */
.side-card { background: var(--navy-mid); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; position: sticky; top: 14px; }

/* On mobile, summary card shows key stats in a compact grid first */
.mobile-summary {
  display: none;
  padding: 14px 16px;
  background: var(--gold-dim);
  border-bottom: 1px solid rgba(201,168,76,0.2);
}
@media (max-width: 700px) {
  .mobile-summary { display: block; }
  /* Re-order: summary card appears between price and loan details */
}
.mobile-summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px; }
.ms-item { }
.ms-label { font-size: 10px; color: var(--gold-light); opacity: .75; text-transform: uppercase; letter-spacing: 0.5px; }
.ms-value { font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 700; color: var(--gold); margin-top: 2px; }
.ms-value.sm { font-size: 13px; }

.verdict-header { padding: 16px 16px 12px; background: var(--navy-light); border-bottom: 1px solid var(--border); }
.verdict-label { font-size: 10px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: var(--slate); margin-bottom: 8px; }
.verdict-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 20px; font-family: 'Space Grotesk', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.3px; }
.verdict-badge.strong  { background: var(--green-dim); color: var(--green); border: 1px solid rgba(46,204,122,0.3); }
.verdict-badge.caution { background: var(--amber-dim); color: var(--amber); border: 1px solid rgba(245,166,35,0.3); }
.verdict-badge.stretch { background: var(--red-dim);   color: var(--red);   border: 1px solid rgba(232,72,90,0.3); }
.verdict-badge.unknown { background: rgba(255,255,255,0.06); color: var(--slate-light); border: 1px solid var(--border); }
.verdict-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; }

.monthly-hero { padding: 14px 16px; background: var(--gold-dim); border-bottom: 1px solid rgba(201,168,76,0.2); }
.monthly-label { font-size: 10px; font-weight: 500; color: var(--gold-light); margin-bottom: 3px; opacity: .85; text-transform: uppercase; letter-spacing: 0.5px; }
.monthly-total { font-family: 'Space Grotesk', sans-serif; font-size: 26px; font-weight: 700; color: var(--gold); letter-spacing: -1px; line-height: 1; }
.monthly-sub { font-size: 10px; color: var(--gold-light); opacity: .6; margin-top: 3px; }

.stat-stack { padding: 10px 16px; }
.stat-item { display: flex; justify-content: space-between; align-items: baseline; padding: 8px 0; border-bottom: 1px solid var(--border); gap: 8px; }
.stat-item:last-child { border-bottom: none; padding-bottom: 0; }
.stat-item:first-child { padding-top: 0; }
.stat-name { font-size: 11px; color: var(--slate); flex: 1; min-width: 0; }
.stat-value { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 700; color: var(--white); text-align: right; white-space: nowrap; }
.stat-value.accent { color: var(--gold); }

.min-income-callout { display: flex; justify-content: space-between; align-items: center; padding: 10px 12px; background: rgba(138,155,176,0.08); border: 1px solid var(--border-strong); border-radius: var(--radius-sm); }
.mic-label { font-size: 11px; color: var(--slate-light); line-height: 1.4; }
.mic-value { font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 700; color: var(--white); white-space: nowrap; margin-left: 8px; }

.income-check { padding: 14px 16px; border-top: 1px solid var(--border); }
.income-label { font-size: 11px; color: var(--slate); margin-bottom: 7px; }
.income-input-wrap { display: flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-strong); border-radius: var(--radius-sm); padding: 9px 10px; }
.income-prefix { font-size: 13px; color: var(--slate); font-family: 'Space Grotesk', sans-serif; font-weight: 600; white-space: nowrap; }
.income-input { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 600; color: var(--white); background: transparent; border: none; outline: none; width: 100%; -moz-appearance: textfield; }
.income-input::-webkit-outer-spin-button, .income-input::-webkit-inner-spin-button { -webkit-appearance: none; }

.dti-bar-wrap { margin-top: 10px; }
.dti-track { height: 5px; background: rgba(255,255,255,0.08); border-radius: 3px; overflow: hidden; margin-bottom: 6px; }
.dti-fill { height: 100%; border-radius: 3px; transition: width .4s ease; background: var(--green); }
.dti-labels { display: flex; justify-content: space-between; font-size: 10px; color: var(--slate); }

/* ── MISC ── */
.info-note { font-size: 10px; color: var(--slate); line-height: 1.5; padding: 8px 10px; background: rgba(255,255,255,0.03); border-radius: var(--radius-sm); border-left: 2px solid rgba(201,168,76,0.3); margin-top: 8px; }
.params-box { background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 12px; margin-bottom: 14px; }
.params-box-label { font-size: 10px; font-weight: 600; color: var(--slate); letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 10px; }
.nht-advance-section { margin-top: 12px; }
.divider { height: 1px; background: var(--border); margin: 2px 0; }
.footer-note { max-width: 980px; margin: 20px auto 0; font-size: 10px; color: var(--slate); text-align: center; line-height: 1.6; opacity: .6; }
</style>
</head>
<body>

<div class="page-header">
  <div>
    <h1 class="page-title">Justin's <span>Property Affordability</span> Calculator</h1>
    <p class="page-subtitle">JMD · Quick affordability assessment for Jamaican residential purchases</p>
  </div>
  <button class="reset-btn" onclick="resetAll()">Reset</button>
</div>

<div class="layout">
<div>

  <!-- ── PRICE + SANITY ── -->
  <div class="card">
    <div class="price-hero">
      <p class="price-label">Purchase / Listing Price</p>
      <div class="price-input-wrap">
        <span class="price-prefix">J$</span>
        <input class="price-input" type="number" inputmode="numeric" id="purchasePrice" value="30000000" placeholder="0" oninput="onPriceChange()" />
      </div>
      <div class="sanity-bar">
        <div class="sanity-track">
          <div class="sanity-fill-loan" id="sanityLoanFill" style="width:0%;background:var(--green);"></div>
          <div class="sanity-fill-deposit" id="sanityDepFill" style="left:0%;width:0%;"></div>
        </div>
        <div class="sanity-labels">
          <span id="sanityLoanLabel">Loans: —</span>
          <span id="sanityDepLabel">Deposit: —</span>
          <span id="sanityPriceLabel">Price: —</span>
        </div>
        <div class="sanity-status" id="sanityStatus"></div>
      </div>
    </div>

    <!-- MOBILE SUMMARY — visible only on small screens, sits right under price -->
    <div class="mobile-summary">
      <p style="font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--gold-light);opacity:.8;">Monthly commitment</p>
      <div style="font-family:'Space Grotesk',sans-serif;font-size:28px;font-weight:700;color:var(--gold);letter-spacing:-1px;margin-top:4px;" id="mMonthlyTotal">—</div>
      <div class="mobile-summary-grid">
        <div class="ms-item"><div class="ms-label">Blended rate</div><div class="ms-value sm" id="mBlended">—</div></div>
        <div class="ms-item"><div class="ms-label">Out-of-pocket</div><div class="ms-value sm" id="mOOP">—</div></div>
        <div class="ms-item"><div class="ms-label">Min. income needed</div><div class="ms-value sm" id="mMinIncome">—</div></div>
        <div class="ms-item"><div class="ms-label">LTV</div><div class="ms-value sm" id="mLTV">—</div></div>
      </div>
    </div>

    <!-- LOAN TABLE -->
    <div class="card-section">
      <p class="section-label">Loan Structure</p>
      <div class="table-scroll">
        <table class="loan-table">
          <thead>
            <tr><th>Facility</th><th>Amount</th><th>Rate</th><th>Term</th><th>Monthly</th></tr>
          </thead>
          <tbody id="loanTableBody"></tbody>
          <tfoot>
            <tr class="total-row">
              <td>Total</td>
              <td id="tTotalAmount">—</td>
              <td id="tBlendedRate">—</td>
              <td>—</td>
              <td id="tTotalMonthly">—</td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <!-- LOAN INPUTS -->
    <div class="card-section">
      <p class="section-label">Loan Parameters</p>

      <div style="margin-bottom:18px;">
        <p style="font-size:11px;font-weight:600;color:#5BB3FF;margin-bottom:10px;letter-spacing:.4px;">
          BANK FINANCING <span class="tag tag-bank">Bank</span> <span class="tag tag-auto" id="bankAutoTag">AUTO</span>
        </p>
        <div class="input-grid col3">
          <div class="field">
            <span class="field-label">Loan Amount (J$)</span>
            <input class="field-input auto" type="number" inputmode="numeric" id="bankAmount" oninput="onBankAmountEdit()" />
            <span class="field-hint auto-hint" id="bankAutoHint">Auto: price − J$9M NHT</span>
          </div>
          <div class="field">
            <span class="field-label">Interest Rate %</span>
            <input class="field-input" type="number" inputmode="decimal" id="bankRate" value="9.00" step="0.01" oninput="recalc()" />
            <span class="field-hint">Standard: 9%</span>
          </div>
          <div class="field">
            <span class="field-label">Term (months)</span>
            <input class="field-input" type="number" inputmode="numeric" id="bankTerm" value="360" oninput="recalc()" />
          </div>
        </div>
        <div class="info-note" id="bankAutoNote">Bank loan snaps to purchase price minus NHT's J$9M. Edit to override for a stronger deposit position.</div>
      </div>

      <div>
        <p style="font-size:11px;font-weight:600;color:var(--gold);margin-bottom:10px;letter-spacing:.4px;">NHT MORTGAGE <span class="tag tag-nht">NHT</span></p>
        <div class="input-grid col2" style="margin-bottom:12px;">
          <div class="field">
            <span class="field-label">Loan Amount (J$)</span>
            <input class="field-input" type="number" inputmode="numeric" id="nhtAmount" value="9000000" oninput="recalc()" />
            <span class="field-hint">Standard: J$9,000,000</span>
          </div>
          <div class="field">
            <span class="field-label">Term (months)</span>
            <input class="field-input" type="number" inputmode="numeric" id="nhtTerm" value="360" oninput="recalc()" />
          </div>
        </div>
        <p style="font-size:10px;font-weight:600;color:var(--slate);letter-spacing:.8px;text-transform:uppercase;margin-bottom:10px;">Your Weekly Income Band</p>
        <div class="band-grid">
          <button class="band-btn" data-rate="0" onclick="selectBand(this)">
            <span class="band-rate">0%</span>
            <span class="band-range">Up to J$30,000/wk</span>
            <span class="band-range">(Min. wage)</span>
          </button>
          <button class="band-btn" data-rate="2" onclick="selectBand(this)">
            <span class="band-rate">2%</span>
            <span class="band-range">J$30,001 – J$42,000/wk</span>
          </button>
          <button class="band-btn active" data-rate="4" onclick="selectBand(this)">
            <span class="band-rate">4%</span>
            <span class="band-range">J$42,001 – J$100,000/wk</span>
          </button>
          <button class="band-btn" data-rate="5" onclick="selectBand(this)">
            <span class="band-rate">5%</span>
            <span class="band-range">J$100,001+/wk</span>
          </button>
        </div>
        <div class="info-note" style="margin-top:10px;">NHT rate set to <strong id="nhtRateDisplay">4.00%</strong> based on selected band.</div>
      </div>
    </div>

    <!-- MONTHLY ADD-ONS -->
    <div class="card-section">
      <p class="section-label">Monthly Add-ons</p>
      <div class="input-grid col2">
        <div class="field">
          <span class="field-label">Maintenance / HOA (J$)</span>
          <input class="field-input" type="number" inputmode="numeric" id="maintenance" value="0" oninput="recalc()" />
          <span class="field-hint">Strata / complex fee</span>
        </div>
        <div class="field">
          <span class="field-label">Property Insurance (J$)</span>
          <input class="field-input auto" type="number" inputmode="numeric" id="insurance" oninput="onInsuranceEdit()" />
          <span class="field-hint auto-hint">Auto: 0.05% of value/mo</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── UPFRONT COSTS ── -->
  <div class="card" style="margin-top:14px;">
    <div class="card-section">
      <p class="section-label">Upfront Transaction Costs</p>

      <div class="params-box">
        <p class="params-box-label">Fee Parameters (editable)</p>
        <div class="input-grid col4">
          <div class="field">
            <span class="field-label">Attorney Fee %</span>
            <input class="field-input" type="number" inputmode="decimal" id="attorneyPct" value="1.25" step="0.01" oninput="recalc()" />
            <span class="field-hint">of purchase price</span>
          </div>
          <div class="field">
            <span class="field-label">Sales Agreement %</span>
            <input class="field-input" type="number" inputmode="decimal" id="salesAgrPct" value="0.20" step="0.01" oninput="recalc()" />
            <span class="field-hint">of purchase price</span>
          </div>
          <div class="field">
            <span class="field-label">NLA Registration %</span>
            <input class="field-input" type="number" inputmode="decimal" id="nlaRegPct" value="0.25" step="0.01" oninput="recalc()" />
            <span class="field-hint">National Land Agency</span>
          </div>
          <div class="field">
            <span class="field-label">Required Deposit %</span>
            <input class="field-input" type="number" inputmode="decimal" id="depositPct" value="10" step="0.5" oninput="recalc()" />
            <span class="field-hint">of purchase price</span>
          </div>
        </div>
      </div>

      <div id="feeBreakdown"></div>

      <div class="subtotal-row">
        <span class="subtotal-label">Deposit + All Fees</span>
        <span class="subtotal-value" id="totalUpfront">—</span>
      </div>

      <div class="nht-advance-section">
        <div class="yn-row">
          <div>
            <p class="yn-label">Are you 35 or under?</p>
            <p class="yn-sub">Eligible for NHT Advance — up to J$2M from your J$9M allocation</p>
          </div>
          <div class="yn-btns">
            <button class="yn-btn active-yes" id="btnYes" onclick="setAge35(true)">YES</button>
            <button class="yn-btn" id="btnNo" onclick="setAge35(false)">NO</button>
          </div>
        </div>
        <div id="nhtAdvanceField">
          <div class="field">
            <span class="field-label">NHT Advance Amount (J$)</span>
            <input class="field-input" type="number" inputmode="numeric" id="nhtAdvanceAmount" value="2000000" oninput="recalc()" />
            <span class="field-hint">Max J$2,000,000 · subject to NHT confirmation</span>
          </div>
        </div>
        <div id="nhtDeductionRow"></div>
        <div class="out-of-pocket">
          <span class="oop-label">Out-of-pocket required</span>
          <span class="oop-value" id="outOfPocket">—</span>
        </div>
      </div>
    </div>
  </div>

</div><!-- end left col -->

<!-- ── SIDEBAR ── -->
<div class="side-card">
  <div class="verdict-header">
    <p class="verdict-label">Quick verdict</p>
    <div class="verdict-badge unknown" id="verdictBadge">
      <div class="verdict-dot"></div>
      <span id="verdictText">Enter income below</span>
    </div>
  </div>

  <div class="monthly-hero">
    <p class="monthly-label">Total monthly commitment</p>
    <div class="monthly-total" id="monthlyTotal">—</div>
    <p class="monthly-sub">mortgage + insurance + maintenance</p>
  </div>

  <div class="stat-stack">
    <div class="stat-item"><span class="stat-name">Mortgage payments</span><span class="stat-value" id="sMortgage">—</span></div>
    <div class="stat-item"><span class="stat-name">Monthly insurance</span><span class="stat-value" id="sInsurance">—</span></div>
    <div class="stat-item"><span class="stat-name">Maintenance / HOA</span><span class="stat-value" id="sMaint">—</span></div>
    <div class="divider"></div>
    <div class="stat-item"><span class="stat-name">Blended interest rate</span><span class="stat-value accent" id="sBlended">—</span></div>
    <div class="stat-item"><span class="stat-name">Total loan borrowed</span><span class="stat-value" id="sTotalLoan">—</span></div>
    <div class="stat-item"><span class="stat-name">Loan-to-value (LTV)</span><span class="stat-value" id="sLTV">—</span></div>
    <div class="stat-item"><span class="stat-name">Out-of-pocket (upfront)</span><span class="stat-value accent" id="sOOP">—</span></div>
  </div>

  <div style="padding: 0 16px 14px;">
    <div class="min-income-callout">
      <span class="mic-label">Min. income for comfortable DTI</span>
      <span class="mic-value" id="minIncomeRequired">—</span>
    </div>
  </div>

  <div class="income-check">
    <p class="income-label">Enter gross monthly income to check DTI</p>
    <div class="income-input-wrap">
      <span class="income-prefix">J$</span>
      <input class="income-input" type="number" inputmode="numeric" id="monthlyIncome" placeholder="e.g. 400,000" oninput="recalc()" />
    </div>
    <div class="dti-bar-wrap" id="dtiBarWrap" style="display:none;">
      <div class="dti-track"><div class="dti-fill" id="dtiFill" style="width:0%;"></div></div>
      <div class="dti-labels"><span id="dtiPct">—</span><span>35% comfort</span><span>50% max</span></div>
    </div>
  </div>
</div>

</div><!-- end layout -->

<p class="footer-note">
  Illustrative purposes only. Consult your mortgage advisor and attorney for confirmed quotations.<br>
  Stamp duty, NHT rates, attorney fees and NLA registration charges subject to revision by relevant authorities.
</p>

<script>
let nhtRate = 4, age35 = true, bankManual = false, insManual = false;

function fmt(n) {
  if (isNaN(n) || n == null) return '—';
  return 'J$' + Math.round(n).toLocaleString('en-US');
}
function pmt(p, r, n) {
  if (!p || p <= 0 || !n || n <= 0) return 0;
  const mr = r / 100 / 12;
  if (mr === 0) return p / n;
  return (p * mr * Math.pow(1 + mr, n)) / (Math.pow(1 + mr, n) - 1);
}

function onPriceChange() {
  const price = parseFloat(document.getElementById('purchasePrice').value) || 0;
  if (!bankManual) {
    const nhtAmt = parseFloat(document.getElementById('nhtAmount').value) || 9000000;
    document.getElementById('bankAmount').value = Math.max(0, price - nhtAmt) || '';
  }
  if (!insManual) {
    document.getElementById('insurance').value = Math.round(price * 0.0005);
  }
  recalc();
}

function onBankAmountEdit() {
  if (!bankManual) {
    bankManual = true;
    document.getElementById('bankAutoTag').style.display  = 'none';
    document.getElementById('bankAutoHint').style.display = 'none';
    document.getElementById('bankAutoNote').style.display = 'none';
    document.getElementById('bankAmount').classList.remove('auto');
  }
  recalc();
}

function onInsuranceEdit() {
  if (!insManual) {
    insManual = true;
    document.getElementById('insurance').classList.remove('auto');
  }
  recalc();
}

function selectBand(btn) {
  document.querySelectorAll('.band-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  nhtRate = parseFloat(btn.dataset.rate);
  document.getElementById('nhtRateDisplay').textContent = nhtRate.toFixed(2) + '%';
  recalc();
}

function setAge35(val) {
  age35 = val;
  document.getElementById('btnYes').className = 'yn-btn' + (val  ? ' active-yes' : '');
  document.getElementById('btnNo').className  = 'yn-btn' + (!val ? ' active-no'  : '');
  document.getElementById('nhtAdvanceField').style.display = val ? 'block' : 'none';
  recalc();
}

function recalc() {
  const price     = parseFloat(document.getElementById('purchasePrice').value) || 0;
  const bankAmt   = parseFloat(document.getElementById('bankAmount').value)    || 0;
  const bankRate  = parseFloat(document.getElementById('bankRate').value)      || 0;
  const bankTerm  = parseInt(document.getElementById('bankTerm').value)        || 360;
  const nhtAmt    = parseFloat(document.getElementById('nhtAmount').value)     || 0;
  const nhtTerm   = parseInt(document.getElementById('nhtTerm').value)         || 360;
  const maint     = parseFloat(document.getElementById('maintenance').value)   || 0;
  const ins       = parseFloat(document.getElementById('insurance').value)     || 0;
  const attPct    = parseFloat(document.getElementById('attorneyPct').value)   || 1.25;
  const salePct   = parseFloat(document.getElementById('salesAgrPct').value)  || 0.20;
  const nlaPct    = parseFloat(document.getElementById('nlaRegPct').value)     || 0.25;
  const depPct    = parseFloat(document.getElementById('depositPct').value)    || 10;
  const nhtAdv    = age35 ? (parseFloat(document.getElementById('nhtAdvanceAmount').value) || 0) : 0;

  // SANITY
  const totalLoan = bankAmt + nhtAmt;
  const deposit   = price * depPct / 100;
  const gap       = price - (totalLoan + deposit);
  const lPct      = price > 0 ? Math.min(totalLoan / price * 100, 100) : 0;
  const dPct      = price > 0 ? Math.min(deposit   / price * 100, 100) : 0;

  document.getElementById('sanityLoanFill').style.width = lPct + '%';
  document.getElementById('sanityDepFill').style.left   = lPct + '%';
  document.getElementById('sanityDepFill').style.width  = dPct + '%';
  document.getElementById('sanityLoanLabel').textContent  = 'Loans: '   + fmt(totalLoan);
  document.getElementById('sanityDepLabel').textContent   = 'Deposit: ' + fmt(deposit);
  document.getElementById('sanityPriceLabel').textContent = 'Price: '   + fmt(price);

  const sEl = document.getElementById('sanityStatus');
  const lFill = document.getElementById('sanityLoanFill');
  if (!price) { sEl.textContent = ''; lFill.style.background = 'var(--slate)'; }
  else if (Math.abs(gap) < 1000) {
    sEl.textContent = '✓ Loan + deposit fully covers purchase price';
    sEl.style.color = 'var(--green)'; lFill.style.background = 'var(--green)';
  } else if (gap > 0) {
    sEl.textContent = '⚠ Shortfall of ' + fmt(gap) + ' — increase deposit or loans';
    sEl.style.color = 'var(--amber)'; lFill.style.background = 'var(--amber)';
  } else {
    sEl.textContent = '↑ Surplus of ' + fmt(Math.abs(gap)) + ' — stronger equity position';
    sEl.style.color = 'var(--slate-light)'; lFill.style.background = '#5BB3FF';
  }

  // FEES
  const GCT        = 0.15;
  const attTotal   = price * attPct  / 100 * (1 + GCT);
  const saleTotal  = price * salePct / 100 * (1 + GCT);
  const nlaReg     = price * nlaPct  / 100;
  const totalFees  = 2500 + attTotal + saleTotal + nlaReg;
  const totalUp    = deposit + totalFees;
  const oop        = Math.max(0, totalUp - nhtAdv);
  const gctNote    = '<span class="fee-gct-note">Incl. 15% GCT</span>';

  document.getElementById('feeBreakdown').innerHTML = `
    <div class="fee-row"><div class="fee-name">Deposit<small>${depPct}% of purchase price</small></div><div class="fee-value">${fmt(deposit)}</div></div>
    <div class="fee-row"><div class="fee-name">Stamp Duty<small>Fixed — buyer's portion</small></div><div class="fee-value">${fmt(2500)}</div></div>
    <div class="fee-row"><div class="fee-name">Attorney Fee<small>${attPct}% of price + 15% GCT</small></div><div class="fee-value">${fmt(attTotal)}${gctNote}</div></div>
    <div class="fee-row"><div class="fee-name">Sales Agreement Fee<small>${salePct}% of price + 15% GCT</small></div><div class="fee-value">${fmt(saleTotal)}${gctNote}</div></div>
    <div class="fee-row"><div class="fee-name">NLA Registration Fee<small>${nlaPct}% — National Land Agency</small></div><div class="fee-value">${fmt(nlaReg)}</div></div>`;

  document.getElementById('totalUpfront').textContent = fmt(totalUp);
  document.getElementById('nhtDeductionRow').innerHTML = age35 && nhtAdv > 0 ? `
    <div class="nht-deduction" style="margin-top:8px;">
      <span class="nht-deduction-label">NHT Advance deducted</span>
      <span class="nht-deduction-value">− ${fmt(nhtAdv)}</span>
    </div>` : '';
  document.getElementById('outOfPocket').textContent = fmt(oop);

  // LOANS
  const bankMo    = pmt(bankAmt, bankRate, bankTerm);
  const nhtMo     = pmt(nhtAmt,  nhtRate,  nhtTerm);
  const totMort   = bankMo + nhtMo;
  const blended   = totalLoan > 0 ? (bankAmt * bankRate + nhtAmt * nhtRate) / totalLoan : 0;
  const ltv       = price > 0 ? totalLoan / price * 100 : 0;
  const totMo     = totMort + ins + maint;
  const minIncome = totMo > 0 ? Math.ceil(totMo / 0.35) : 0;

  document.getElementById('loanTableBody').innerHTML = `
    <tr>
      <td>Bank Financing <span class="tag tag-bank">Bank</span></td>
      <td>${fmt(bankAmt)}</td><td>${bankRate.toFixed(2)}%</td><td>${bankTerm}</td><td>${fmt(bankMo)}</td>
    </tr>
    <tr>
      <td>NHT <span class="tag tag-nht">NHT</span></td>
      <td>${fmt(nhtAmt)}</td><td>${nhtRate.toFixed(2)}%</td><td>${nhtTerm}</td><td>${fmt(nhtMo)}</td>
    </tr>`;
  document.getElementById('tTotalAmount').textContent  = fmt(totalLoan);
  document.getElementById('tBlendedRate').textContent  = blended > 0 ? blended.toFixed(2) + '%' : '—';
  document.getElementById('tTotalMonthly').textContent = fmt(totMort);

  // SIDEBAR
  const vals = {
    monthlyTotal: fmt(totMo), sMortgage: fmt(totMort),
    sInsurance: fmt(ins), sMaint: fmt(maint),
    sBlended: blended > 0 ? blended.toFixed(2) + '%' : '—',
    sTotalLoan: fmt(totalLoan), sLTV: ltv > 0 ? ltv.toFixed(1) + '%' : '—',
    sOOP: fmt(oop), minIncomeRequired: minIncome > 0 ? fmt(minIncome) : '—'
  };
  Object.entries(vals).forEach(([id, v]) => { const el = document.getElementById(id); if (el) el.textContent = v; });

  // MOBILE SUMMARY
  document.getElementById('mMonthlyTotal').textContent = fmt(totMo);
  document.getElementById('mBlended').textContent      = blended > 0 ? blended.toFixed(2) + '%' : '—';
  document.getElementById('mOOP').textContent          = fmt(oop);
  document.getElementById('mMinIncome').textContent    = minIncome > 0 ? fmt(minIncome) : '—';
  document.getElementById('mLTV').textContent          = ltv > 0 ? ltv.toFixed(1) + '%' : '—';

  // DTI
  const income = parseFloat(document.getElementById('monthlyIncome').value) || 0;
  const dtiWrap = document.getElementById('dtiBarWrap');
  const verdict = document.getElementById('verdictBadge');
  const vText   = document.getElementById('verdictText');
  const fill    = document.getElementById('dtiFill');

  if (income > 0) {
    dtiWrap.style.display = 'block';
    const dti = totMo / income * 100;
    fill.style.width = Math.min(dti, 100) + '%';
    document.getElementById('dtiPct').textContent = dti.toFixed(1) + '% DTI';
    if (dti <= 30)      { fill.style.background = 'var(--green)'; verdict.className = 'verdict-badge strong';  vText.textContent = 'Strong — comfortably affordable'; }
    else if (dti <= 40) { fill.style.background = 'var(--amber)'; verdict.className = 'verdict-badge caution'; vText.textContent = 'Caution — manageable, watch spend'; }
    else                { fill.style.background = 'var(--red)';   verdict.className = 'verdict-badge stretch'; vText.textContent = 'Stretch — affordability at risk'; }
  } else {
    dtiWrap.style.display = 'none';
    verdict.className = 'verdict-badge unknown';
    vText.textContent = 'Enter income for verdict';
  }
}

function resetAll() {
  bankManual = false; insManual = false;
  document.getElementById('bankAmount').classList.add('auto');
  ['bankAutoTag','bankAutoHint','bankAutoNote'].forEach(id => document.getElementById(id).style.display = '');
  document.getElementById('insurance').classList.add('auto');
  const d = {
    purchasePrice: 30000000, bankRate: 9.00, bankTerm: 360,
    nhtAmount: 9000000, nhtTerm: 360, maintenance: 0,
    attorneyPct: 1.25, salesAgrPct: 0.20, nlaRegPct: 0.25,
    depositPct: 10, nhtAdvanceAmount: 2000000
  };
  Object.entries(d).forEach(([id, v]) => { const e = document.getElementById(id); if (e) e.value = v; });
  document.getElementById('monthlyIncome').value = '';
  document.querySelectorAll('.band-btn').forEach(b => {
    b.classList.remove('active');
    if (b.dataset.rate === '4') b.classList.add('active');
  });
  nhtRate = 4;
  document.getElementById('nhtRateDisplay').textContent = '4.00%';
  setAge35(true);
  onPriceChange();
}

onPriceChange();
</script>
</body>
</html>
